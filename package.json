{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <25"
  },
  "scripts": {
    "test": "pnpm run securityCheck && pnpm run format:check && pnpm run lint && pnpm run type-check",
    "securityCheck": "pnpm audit --audit-level high",
    "format:check": "pnpm --filter @my-app/ui-spec-designer run format:check",
    "lint": "pnpm --filter @my-app/ui-spec-designer run lint",
    "type-check": "pnpm --filter @my-app/ui-spec-designer run type-check",
    "spec:dev": "pnpm --filter @my-app/ui-spec-designer run dev",
    "spec:build": "pnpm --filter @my-app/ui-spec-designer run build",
    "artifacts:capture": "pnpm --filter @my-app/generate-ui-screens run capture",
    "e2e:web": "pnpm --filter @my-app/e2e run e2e:run",
    "pipeline:capture": "pnpm spec:build && start-test \"pnpm dlx http-server .generated/reports/storybook-static -p 6006 -c-1\" http://localhost:6006 \"pnpm artifacts:capture\"",
    "clean": "pnpm -r run clean && rimraf .generated",
    "bumpDependencies": "pnpm -r run bumpDependencies",
    "release": "node --experimental-strip-types scripts/release.ts",
    "release:dry-run": "node --experimental-strip-types scripts/release.ts --dry-run",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@release-it/bumper": "^7.0.5",
    "@release-it/conventional-changelog": "^10.0.6",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "release-it": "^20.0.0",
    "rimraf": "^6.1.3",
    "start-server-and-test": "^3.0.2"
  }
}
