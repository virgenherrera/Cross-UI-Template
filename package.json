{
  "name": "cross-ui-template",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <25"
  },
  "scripts": {
    "test": "pnpm run securityCheck && pnpm run format:check && pnpm run lint && pnpm run type-check",
    "securityCheck": "pnpm audit --audit-level high",
    "format:check": "pnpm --filter @cross-ui/ui-spec-designer run format:check",
    "lint": "pnpm --filter @cross-ui/ui-spec-designer run lint",
    "type-check": "pnpm --filter @cross-ui/ui-spec-designer run type-check",
    "spec:dev": "pnpm --filter @cross-ui/ui-spec-designer run dev",
    "spec:build": "pnpm --filter @cross-ui/ui-spec-designer run build",
    "app:dev": "pnpm --filter @cross-ui/web run dev",
    "app:build": "pnpm --filter @cross-ui/web run build",
    "artifacts:capture": "pnpm --filter @cross-ui/generate-ui-screens run capture",
    "e2e:web": "pnpm --filter @cross-ui/e2e run e2e:run",
    "e2e:web:pw": "pnpm --filter @cross-ui/e2e run e2e:web",
    "pipeline:capture": "pnpm spec:build && start-test \"pnpm dlx http-server .generated/reports/storybook-static -p 6006 -c-1\" http://localhost:6006 \"pnpm artifacts:capture\"",
    "pipeline:validate": "start-test \"pnpm dlx http-server apps/web -p 8080 -c-1\" http://localhost:8080 \"pnpm e2e:web\"",
    "pipeline:full": "pnpm pipeline:capture && pnpm pipeline:validate",
    "clean": "pnpm -r run clean && rm -rf .generated",
    "init": "./scripts/init.sh",
    "bumpDependencies": "pnpm -r run bumpDependencies",
    "release": "node --experimental-strip-types scripts/release.ts",
    "release:dry-run": "node --experimental-strip-types scripts/release.ts --dry-run",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@release-it/bumper": "^7.0.5",
    "@release-it/conventional-changelog": "^10.0.6",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "release-it": "^20.0.0",
    "start-server-and-test": "^3.0.2"
  }
}
