{
  "name": "formo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <25"
  },
  "scripts": {
    "test": "pnpm run securityCheck && pnpm run format:check && pnpm run lint && pnpm run type-check",
    "securityCheck": "pnpm audit --audit-level high",
    "format:check": "pnpm --filter @formo/ui-spec-designer --filter @formo/mobile run format:check",
    "lint": "pnpm --filter @formo/ui-spec-designer --filter @formo/mobile run lint",
    "type-check": "pnpm --filter @formo/ui-spec-designer --filter @formo/mobile run type-check",
    "spec:dev": "pnpm --filter @formo/ui-spec-designer run dev",
    "spec:build": "pnpm --filter @formo/ui-spec-designer run build",
    "artifacts:capture": "pnpm --filter @formo/generate-ui-screens run capture",
    "app:android": "pnpm --filter @formo/mobile run dev:android",
    "app:tailwind": "pnpm --filter @formo/mobile run tailwind:watch",
    "app:tailwind:build": "pnpm --filter @formo/mobile run tailwind:build",
    "app:ios": "pnpm --filter @formo/mobile run dev:ios",
    "app:build:android": "pnpm --filter @formo/mobile run build:android",
    "app:build:ios": "pnpm --filter @formo/mobile run build:ios",
    "e2e:web": "pnpm --filter @formo/e2e run e2e:run",
    "e2e:web:pw": "pnpm --filter @formo/e2e run e2e:web",
    "smoke:ios": "pnpm --filter @formo/e2e-maestro-smoke run smoke:ios",
    "smoke:android": "pnpm --filter @formo/e2e-maestro-smoke run smoke:android",
    "pipeline:capture": "pnpm spec:build && start-test \"pnpm dlx http-server .generated/reports/storybook-static -p 6006 -c-1\" http://localhost:6006 \"pnpm artifacts:capture\"",
    "clean": "pnpm -r run clean && rimraf .generated",
    "bumpDependencies": "pnpm -r run bumpDependencies",
    "release": "node --experimental-strip-types scripts/release.ts",
    "release:dry-run": "node --experimental-strip-types scripts/release.ts --dry-run",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@release-it/bumper": "^7.0.5",
    "@release-it/conventional-changelog": "^10.0.6",
    "@tailwindcss/cli": "^4.2.2",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "release-it": "^20.0.0",
    "rimraf": "^6.1.3",
    "start-server-and-test": "^3.0.2",
    "tailwindcss": "^4.2.2"
  }
}
